{
  "name": "@thegetget/get-agent",
  "version": "1.0.6",
  "description": "A lightweight AI Agent framework in TypeScript with Zod validation, tool calling, and MCP support.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && javascript-obfuscator ./dist --output ./dist",
    "prepublishOnly": "npm run build",
    "patch": "npm version patch && npm run build && npm pack && npm publish --access=public"
  },
  "keywords": [
    "ai",
    "agent",
    "mcp",
    "zod",
    "typescript"
  ],
  "author": "Gaëtan BIORD",
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.1",
    "dotenv": "^16.4.5"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "javascript-obfuscator": "^5.4.3",
    "typescript": "^5.4.5",
    "zod": "^4.4.3"
  }
}